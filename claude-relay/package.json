{
  "name": "claude-relay",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/parser tests/analyzer --verbose",
    "test:prometheus": "jest tests/prometheus --verbose --forceExit",
    "test:api": "jest tests/routes --verbose",
    "test:ws": "jest tests/websocket --verbose",
    "test:multi": "jest tests/multiinstance --verbose",
    "test:perf": "jest tests/performance --verbose",
    "test:brain": "jest tests/brain --verbose --forceExit",
    "test:decision": "jest tests/decision-engine --verbose --forceExit",
    "test:validator": "jest tests/auto-validator --verbose --forceExit",
    "test:memory": "jest tests/project-memory --verbose --forceExit",
    "test:watchdog": "jest tests/watchdog --verbose --forceExit",
    "test:e2e": "jest tests/e2e-autonomous --verbose --forceExit",
    "test:all": "jest --runInBand --forceExit --verbose --coverage",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop claude-relay",
    "pm2:logs": "pm2 logs claude-relay",
    "pm2:status": "pm2 status",
    "install:launchagent": "cp com.clauderelay.plist ~/Library/LaunchAgents/ && launchctl load ~/Library/LaunchAgents/com.clauderelay.plist",
    "uninstall:launchagent": "launchctl unload ~/Library/LaunchAgents/com.clauderelay.plist"
  },
  "keywords": [],
