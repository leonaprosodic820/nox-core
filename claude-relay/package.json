    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "node-notifier": "^10.0.1",
    "node-telegram-bot-api": "^0.67.0",
    "open": "^11.0.0",
    "qrcode": "^1.5.4",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "uuid": "^14.0.0",
    "ws": "^8.20.0"
